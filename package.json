{
  "name": "gestione-negozio",
  "version": "1.0.0",
  "description": "Gestione negozio semplice e veloce",
  "main": "out/main/index.js",
  "author": "Enrico Giusto",
  "homepage": "Linux Every day",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && npm run rebuild:native && electron-builder --dir",
    "build:win": "npm run build && npm run rebuild:native && electron-builder --win",
    "build:mac": "npm run build && npm run rebuild:native && electron-builder --mac",
    "build:linux": "npm run build && npm run rebuild:native && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.3.9",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.14.0",
    "react-barcode": "^1.6.1",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.5.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.14",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^3.4.19",
    "vite": "^7.2.6"
  },
"build": {
  "appId": "com.drgreen.gestionenegozio",
  "productName": "gestione-negozio",
  "directories": {
    "buildResources": "build"
  },
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "mac": {
    "icon": "build/icon.icns"
  },
  "linux": {
    "icon": "build/icon.png"
  }
}
}